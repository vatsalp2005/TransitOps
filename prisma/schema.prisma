// TransitOps — Smart Transport Operations Platform
// Database schema. Postgres. Designed for referential integrity, correct types,
// normalization, and the business rules in the spec.
//
// Design notes:
//  - Money is Decimal(12,2); distances/weights Decimal to avoid float drift.
//  - Every table has created_at / updated_at.
//  - Status fields are enums (CHECK-constrained at the DB level), never free text.
//  - Foreign keys everywhere related data is referenced (no loose ids).
//  - Indexes on FKs + frequently filtered columns (status, dates).
//  - AuditLog gives an immutable history trail (also powers "real-time" activity).

// Engine-free client (WASM query compiler + pg driver adapter). Required because
// this platform is Windows ARM64, for which Prisma ships no native query engine.
generator client {
  provider   = "prisma-client"
  output     = "../src/generated/prisma"
  runtime    = "nodejs"
  engineType = "client"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---------------------------------------------------------------------------
// Enums
// ---------------------------------------------------------------------------

enum RoleKey {
  FLEET_MANAGER
  DRIVER
  SAFETY_OFFICER
  FINANCIAL_ANALYST
}

enum VehicleType {
  VAN
  TRUCK
  CAR
  BUS
  PICKUP
}

/// Indian state / union-territory the vehicle is based in.
/// Codes match the map geometry in src/lib/india-map.ts.
enum Region {
  AN
  AP
  AR
  AS
  BR
  CH
  CT
  DD
  DL
  DN
  GA
  GJ
  HP
  HR
  JH
  JK
  KA
  KL
  LA
  LD
  MH
  ML
  MN
  MP
  MZ
  NL
  OR
  PB
  PY
  RJ
  SK
  TG
  TN
  TR
  UP
  UT
  WB
}

enum VehicleStatus {
  AVAILABLE
  ON_TRIP
  IN_SHOP
  RETIRED
}

enum LicenseCategory {
  LMV // Light Motor Vehicle
  HMV // Heavy Motor Vehicle
  MCWG // Motorcycle with Gear
  PSV // Public Service Vehicle
  TRANS // Transport / Hazardous
}

enum DriverStatus {
  AVAILABLE
  ON_TRIP
  OFF_DUTY
  SUSPENDED
}

enum TripStatus {
  DRAFT
  DISPATCHED
  COMPLETED
  CANCELLED
}

enum MaintenanceType {
  OIL_CHANGE
  ENGINE_REPAIR
  TIRE_REPLACE
  BRAKE_SERVICE
  INSPECTION
  BODY_REPAIR
  OTHER
}

enum MaintenanceStatus {
  OPEN // vehicle is In Shop
  CLOSED // service completed
}

enum ExpenseType {
  TOLL
  PARKING
  PERMIT
  FINE
  INSURANCE
  MISC
}

enum AuditAction {
  CREATE
  UPDATE
  DELETE
  DISPATCH
  COMPLETE
  CANCEL
  MAINTENANCE_OPEN
  MAINTENANCE_CLOSE
}

// ---------------------------------------------------------------------------
// Identity & access
// ---------------------------------------------------------------------------

model Role {
  id          String   @id @default(cuid())
  key         RoleKey  @unique
  name        String
  description String?
  // Per-module access map, e.g. { "vehicles": "edit", "reports": "view" }.
  // Value is one of: none | view | edit. Enforced in the service layer.
  permissions Json
  users       User[]
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("roles")
}

model User {
  id           String     @id @default(cuid())
  email        String     @unique
  passwordHash String     @map("password_hash")
  name         String
  roleId       String     @map("role_id")
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Restrict)
  isActive     Boolean    @default(true) @map("is_active")
  lastLoginAt  DateTime?  @map("last_login_at")

  // Brute-force protection: the account locks after 5 consecutive failures.
  failedAttempts Int       @default(0) @map("failed_attempts")
  lockedUntil    DateTime? @map("locked_until")

  createdTrips Trip[]               @relation("TripCreatedBy")
  auditLogs    AuditLog[]           @relation("AuditActor")
  resetTokens  PasswordResetToken[]
  createdAt    DateTime             @default(now()) @map("created_at")
  updatedAt    DateTime             @updatedAt @map("updated_at")

  @@index([roleId])
  @@map("users")
}

/// Single-use, expiring token emailed to a user for password reset.
model PasswordResetToken {
  id        String    @id @default(cuid())
  token     String    @unique
  userId    String    @map("user_id")
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime  @map("expires_at")
  usedAt    DateTime? @map("used_at")
  createdAt DateTime  @default(now()) @map("created_at")

  @@index([userId])
  @@map("password_reset_tokens")
}

// ---------------------------------------------------------------------------
// Fleet
// ---------------------------------------------------------------------------

model Vehicle {
  id              String            @id @default(cuid())
  registrationNo  String            @unique @map("registration_no")
  name            String
  type            VehicleType
  maxLoadKg       Decimal           @map("max_load_kg") @db.Decimal(10, 2)
  odometerKm      Int               @default(0) @map("odometer_km")
  acquisitionCost Decimal           @map("acquisition_cost") @db.Decimal(12, 2)
  status          VehicleStatus     @default(AVAILABLE)
  region          Region            @default(MH)
  trips           Trip[]
  maintenanceLogs MaintenanceLog[]
  fuelLogs        FuelLog[]
  expenses        Expense[]
  createdAt       DateTime          @default(now()) @map("created_at")
  updatedAt       DateTime          @updatedAt @map("updated_at")

  @@index([status])
  @@index([type])
  @@index([region])
  @@map("vehicles")
}

model Driver {
  id              String          @id @default(cuid())
  name            String
  licenseNo       String          @unique @map("license_no")
  licenseCategory LicenseCategory @map("license_category")
  licenseExpiry   DateTime        @map("license_expiry") @db.Date
  contact         String
  safetyScore     Int             @default(100) @map("safety_score") // 0-100
  status          DriverStatus    @default(AVAILABLE)
  trips           Trip[]
  createdAt       DateTime        @default(now()) @map("created_at")
  updatedAt       DateTime        @updatedAt @map("updated_at")

  @@index([status])
  @@index([licenseExpiry])
  @@map("drivers")
}

// ---------------------------------------------------------------------------
// Operations
// ---------------------------------------------------------------------------

model Trip {
  id              String     @id @default(cuid())
  code            String     @unique // human-friendly, e.g. TRP-0001
  source          String
  destination     String
  vehicleId       String     @map("vehicle_id")
  vehicle         Vehicle    @relation(fields: [vehicleId], references: [id], onDelete: Restrict)
  driverId        String     @map("driver_id")
  driver          Driver     @relation(fields: [driverId], references: [id], onDelete: Restrict)
  cargoWeightKg   Decimal    @map("cargo_weight_kg") @db.Decimal(10, 2)
  plannedDistance Decimal    @map("planned_distance_km") @db.Decimal(10, 2)
  status          TripStatus @default(DRAFT)
  revenue         Decimal    @default(0) @db.Decimal(12, 2)
  startOdometer   Int?       @map("start_odometer")
  endOdometer     Int?       @map("end_odometer")
  fuelConsumedL   Decimal?   @map("fuel_consumed_l") @db.Decimal(10, 2)
  dispatchedAt    DateTime?  @map("dispatched_at")
  completedAt     DateTime?  @map("completed_at")
  cancelledAt     DateTime?  @map("cancelled_at")
  createdById     String?    @map("created_by_id")
  createdBy       User?      @relation("TripCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  fuelLogs        FuelLog[]
  expenses        Expense[]
  createdAt       DateTime   @default(now()) @map("created_at")
  updatedAt       DateTime   @updatedAt @map("updated_at")

  @@index([status])
  @@index([vehicleId])
  @@index([driverId])
  @@index([createdAt])
  @@map("trips")
}

model MaintenanceLog {
  id          String            @id @default(cuid())
  vehicleId   String            @map("vehicle_id")
  vehicle     Vehicle           @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  type        MaintenanceType
  description String
  cost        Decimal           @default(0) @db.Decimal(12, 2)
  odometerKm  Int?              @map("odometer_km")
  status      MaintenanceStatus @default(OPEN)
  openedAt    DateTime          @default(now()) @map("opened_at")
  closedAt    DateTime?         @map("closed_at")
  createdAt   DateTime          @default(now()) @map("created_at")
  updatedAt   DateTime          @updatedAt @map("updated_at")

  @@index([vehicleId])
  @@index([status])
  @@map("maintenance_logs")
}

model FuelLog {
  id         String   @id @default(cuid())
  vehicleId  String   @map("vehicle_id")
  vehicle    Vehicle  @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  tripId     String?  @map("trip_id")
  trip       Trip?    @relation(fields: [tripId], references: [id], onDelete: SetNull)
  liters     Decimal  @db.Decimal(10, 2)
  cost       Decimal  @db.Decimal(12, 2)
  odometerKm Int?     @map("odometer_km")
  filledAt   DateTime @default(now()) @map("filled_at")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  @@index([vehicleId])
  @@index([tripId])
  @@index([filledAt])
  @@map("fuel_logs")
}

model Expense {
  id        String      @id @default(cuid())
  vehicleId String      @map("vehicle_id")
  vehicle   Vehicle     @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  tripId    String?     @map("trip_id")
  trip      Trip?       @relation(fields: [tripId], references: [id], onDelete: SetNull)
  type      ExpenseType
  amount    Decimal     @db.Decimal(12, 2)
  note      String?
  spentAt   DateTime    @default(now()) @map("spent_at")
  createdAt DateTime    @default(now()) @map("created_at")
  updatedAt DateTime    @updatedAt @map("updated_at")

  @@index([vehicleId])
  @@index([tripId])
  @@index([spentAt])
  @@map("expenses")
}

// ---------------------------------------------------------------------------
// Audit trail — immutable history of state-changing actions.
// ---------------------------------------------------------------------------

model AuditLog {
  id         String      @id @default(cuid())
  entity     String // e.g. "Vehicle", "Trip"
  entityId   String      @map("entity_id")
  action     AuditAction
  summary    String // human-readable, e.g. "Dispatched trip TRP-0001"
  metadata   Json? // before/after snapshot when useful
  actorId    String?     @map("actor_id")
  actor      User?       @relation("AuditActor", fields: [actorId], references: [id], onDelete: SetNull)
  createdAt  DateTime    @default(now()) @map("created_at")

  @@index([entity, entityId])
  @@index([createdAt])
  @@map("audit_logs")
}
